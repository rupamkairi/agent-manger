{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@weave/shared": ["./packages/shared/src"],
      "@weave/mcp": ["./packages/mcp/src/server.ts"],
      "@weave/server/app": ["./packages/server/src/app.ts"],
      "@weave/server/lockfile": ["./packages/server/src/lib/lockfile.ts"]
    }
  }
}
